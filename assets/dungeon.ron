// Dungeon generation config — the single source of truth for the coarse WFC, room sizing, and the
// liminality dial (see `DungeonConfig` in src/dungeon.rs). REQUIRED at startup: a missing or malformed
// file is a loud panic, mirroring assets/placement/metropolis.ron and furniture.ron — never a silent
// default world (one path, no fallback).
//
// 1 tile = 1 m. Room footprints are real residential metric ranges (Merrell, Schkufza & Koltun,
// "Computer-Generated Residential Building Layouts"; Smelik et al. survey, cgf.12276). `area` is in m²
// (= tiles²); `aspect` = long/short side ratio (>= 1). `weight` biases how often a type is chosen.
(
    coarse_w: 6,
    coarse_h: 6,
    block: 32,
    corridor_width: 2,          // today's carve: block-centre lane + 1 more
    seed: 0x5C09191,            // nods to SCP-9191, the slop generator
    max_attempts: 20,

    // Liminality dial: 1.0 = sparse Backrooms boxes adrift in the void (today's look);
    // 0.0 = realistic contiguous rooms sharing walls (consumed in Phase 2). Default = today.
    liminality: 1.0,

    // The six coarse WFC prototype weights (shape distribution): rock is heavily favoured so rooms
    // float in negative space; corner/corridor rooms dominate the floor set.
    wfc_weights: (
        rock: 6.0, dead_end: 1.2, corridor: 2.5, corner: 2.5, tee: 1.2, cross: 0.6,
    ),

    // Weighted room classes. Sized by TYPE, not one uniform draw — a 3 m² bathroom next to a 40 m²
    // living room reads at believable human scale. Furniture couples to these tags at generation time.
    room_types: [
        ( tag: "bathroom", area_min: 3.0,  area_max: 6.0,   aspect_min: 1.0, aspect_max: 1.6, weight: 0.8 ),
        ( tag: "bedroom",  area_min: 9.0,  area_max: 20.0,  aspect_min: 1.0, aspect_max: 1.5, weight: 1.5 ),
        ( tag: "office",   area_min: 9.0,  area_max: 16.0,  aspect_min: 1.0, aspect_max: 1.5, weight: 1.0 ),
        ( tag: "kitchen",  area_min: 9.0,  area_max: 18.0,  aspect_min: 1.0, aspect_max: 1.5, weight: 1.0 ),
        ( tag: "living",   area_min: 16.0, area_max: 40.0,  aspect_min: 1.0, aspect_max: 1.7, weight: 1.6 ),
        ( tag: "hall",     area_min: 60.0, area_max: 250.0, aspect_min: 1.2, aspect_max: 3.0, weight: 0.4 ),
    ],
)
