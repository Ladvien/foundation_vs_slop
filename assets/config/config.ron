                    volva_radius_m: 0.00320,
                    radius_profile: (0.0032, 0.0031, 0.0031, 0.0031, 0.0030, 0.0029, 0.0029, 0.0028, 0.0028, 0.0028, 0.0027, 0.0027, 0.0027, 0.0160, 0.0152, 0.0113),
                    bend_lo_m: 0.05395,
                    bend_hi_m: 0.07165,
                ),
            ),
            (
                name: "Turkey Tail",
                archetype: "bracket",
                growth_glb: "mushrooms/turkey_tail/TurkeyTail_Growth.glb",
                body_scale: 4.0,
                light: Photophobic,
                toxicity: 0.0,
                nutrition: 0.2,
                room_affinity: [
                    (tag: "hall", weight: 2.0),
                    (tag: "office", weight: 1.5),
                ],
                colors: (
                    cap_young: (0.4650, 0.3800, 0.2675),
                    cap_old: (0.2093, 0.1710, 0.1204),
                    stipe: (0.3165, 0.2522, 0.1745),
                    volva: (0.3165, 0.2522, 0.1745),
                    substrate: (0.0460, 0.0510, 0.0450),
                ),
                geom: (
                    stage_max_disp: (0.00081, 0.00538, 0.00871, 0.00987, 0.00935, 0.00490),
                    stage_height_m: (0.02310, 0.02311, 0.02322, 0.02341, 0.02362, 0.02381, 0.02390),
                    egg_height_m: 0.02310,
                    cap_radius_m: 0.03800,
                    volva_radius_m: 0.03800,
                    radius_profile: (0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0380, 0.0347, 0.0280, 0.0179),
                    bend_lo_m: 0.01530,
                    bend_hi_m: 0.02032,
                ),
            ),
        ],
    ),

    // =============================================================================================
    // dialogue — authored conversation graph (see `DialogueScript`/`Node` in src/dialogue/model.rs).
    // A set of named conversations; each is a node graph keyed by id. Speakers are squad-member
    // indices 0..=4 (0 = leader). `kind` defaults to Speech; `emotion` defaults to Neutral. `Line`
    // advances to `next` (None ends the conversation); `Choice` presents clickable option bubbles
    // above the leader and branches on the pick. Cloned into a `DialogueScript` resource at startup.
    // =============================================================================================
    dialogue: (
        conversations: {
            "intro": (
                start: "open",
                nodes: {
                    "open": Line(
                        speaker: 0,
                        kind: Speech,
                        text: "Foundation, we're through the airlock. Containment breach ahead.",
                        next: Some("dread"),
                    ),
                    "dread": Line(
                        speaker: 1,
                        kind: Thought,
                        emotion: Fear,
                        text: "Whatever SCP-9191 made... it's still in here with us.",
                        next: Some("ask"),
                    ),
                    "ask": Choice(
                        speaker: 0,
                        prompt: "How do we play this?",
                        options: [
                            (text: "Push forward, weapons hot.", next: "push"),
                            (text: "Hold and sweep the room first.", next: "hold"),
                        ],
                    ),
                    "push": Line(
                        speaker: 0,
                        kind: Speech,
                        emotion: Anger,
                        text: "Copy. Stack up and move — don't give it time to think.",
                        next: Some("close"),
                    ),
                    "hold": Line(
                        speaker: 0,
                        kind: Speech,
                        emotion: Calm,
                        text: "Smart. Eyes on the corners. Nobody moves until it's clear.",
                        next: Some("close"),
                    ),
                    "close": Line(
                        speaker: 1,
                        kind: Thought,
                        emotion: Calm,
                        text: "Okay. Stay sharp. We've got this.",
                        next: None,
                    ),
                },
            ),
        },
    ),
    // =============================================================================================
    // lighting — diegetic fluorescent fixtures + environment fill (see `light::LightingConfig`).
    // Fixtures are placed as furniture (`category: "light"`, `affordances: ["emit"]`); each becomes one
    // real clustered PointLight in the windowed game. ambient/directional are the flat Backrooms fill,
    // read by `world::WorldPlugin` (also present in the headless harness — pure light data).
    // =============================================================================================
    lighting: (
        ambient_brightness: 200.0,             // was a flat 500; dimmed so fixtures read as lit pools
        ambient_color: (1.0, 0.98, 0.9),       // warm fluorescent white
        key_illuminance: 2000.0,               // weak steep directional fill (lux)
        fixture_intensity: 120000.0,           // per-fixture lumens (Bevy's default cinema light = 1e6)
        fixture_range: 7.0,                    // metres — area-of-effect cutoff, tuned with intensity
        fixture_color: (0.92, 1.0, 0.94),      // cool white, faint green cast (low-CRI halophosphate)
        fixture_emissive: 2.2,                 // mesh-glow strength (LDR); the visible "light is on" cue
        field_intensity: 1.0,                  // gameplay illuminance per fixture in the LightField (0..1-ish)
        photophobic_gain: 6.0,                 // idle crabs steer down the light gradient (toward dark) at this strength; committed/roused crabs (Muster/Rally/Latch/Carry) ignore it and flood the lit room — see crab_locomotion
        photophilic_gain: 14.0,                // light-seekers steer up the gradient (toolkit; no carrier yet)
        mushroom_light_size_bonus: 0.5,        // death caps grow up to +50% bigger under a lamp (photomorphogenesis)
        mushroom_light_size_rate: 0.25,        // scale-units/sec the size bonus eases in (slow, sub-perceptual)
        flicker_hum_depth: 0.06,               // cosmetic fluorescent shimmer depth (fraction)
        flicker_fail_ratio: 0.12,              // ~1 in 8 tubes is a failing/strobing Backrooms fluorescent
        // The Researcher's flashlight — a moving directional emitter in the LightField (repels photophobes)
        flashlight_intensity: 3.0,             // gameplay peak illuminance at the beam origin (>fixtures, so it drives crabs off)
        flashlight_range: 8.0,                 // beam reach in dungeon cells (wall-occluded like a fixture)
        flashlight_cone_cos: 0.82,             // cos(~35deg) half-angle — a tight torch wedge
        flashlight_edge_softness: 0.15,        // soft rim: cone fades 0->1 over this cosine width
        flashlight_spot_intensity: 200000.0,   // cosmetic real SpotLight lumens (windowed-only glow)
        flashlight_spot_range: 12.0,           // cosmetic beam reach (metres)
        flashlight_spot_color: (1.0, 0.95, 0.8), // warm torch beam
        flashlight_spot_outer_angle: 0.6,      // cosmetic beam half-angle (radians, ~34deg)
    ),
    // Almond Water (src/almond_water/) — a finite, self-regenerating heal resource that seeps from the
    // concrete and pools on the floor. Gameplay knobs drive the CPU field + consuming heal (harness-visible,
    // pinned); the trailing visual knobs are read only by the windowed iridescent-puddle plugin. Tuned
    // high-volume so pools rarely run dry under normal play, leaving a wounded-swarm drain as the exception.
    almond_water: (
        strong_seep: 8.0,          // seep/sec at a spring (sparse wall-adjacent/mold cell) — only springs seep
        pool_spacing: 8.0,         // min tiles between springs — caps each pool to a small, isolated puddle
        capacity: 100.0,           // per-cell volume ceiling — a rich seep pools but never runs away
        evaporate: 0.05,           // fraction dried per sec; steady state ≈ seep/evaporate (weak≈40, wall→cap)
        diffuse: 0.02,             // blend toward 4-neighbour avg per tick — kept low so a pool stays a tight
                                   // puddle (decay length √(15·diffuse/evaporate) cells) instead of a wide sheet
        heal_rate: 5.0,            // HP/sec restored to a biological standing in water (rate-limited like the medic)
        heal_per_unit_water: 1.5,  // water drunk per HP healed — the consumable coupling (drains the cell)
        forage_gain: 10.0,         // steering gain a WOUNDED creature feels climbing the water gradient
        forage_wounded_frac: 0.6,  // forage only at/below 60% health; a healthy creature ignores the water
        // --- Belief / inversion (gameplay; the water does what the population believes) ---
        belief_prior: 1.0,         // heal-reading baseline for non-cyanide pools: 0 = cyanide/poison, 1 = heal
        belief_relax: 0.05,        // rate/sec belief relaxes back toward each pool's seeded base (rumors fade)
        belief_diffuse: 0.02,      // blend toward 4-neighbour belief avg per tick — rumor spreads between pools
        belief_poison_frac: 0.15,  // fraction of floor cells seeded as cyanide (base belief 0) at the bake
        belief_flip_hi: 0.6,       // belief >= this HEALS; the band (lo,hi) is an inert deadband (no oscillation)
        belief_flip_lo: 0.4,       // belief <= this POISONS (pre-drift cyanide reading)
        poison_rate: 5.0,          // HP/sec lost drinking a fully-cyanide pool — the signed twin of heal_rate
        rumor_gain: 0.5,           // belief nudge/sec a SAFE drink deposits toward the heal reading
        death_rumor_gain: 1.0,     // belief nudge/sec a POISONING deposits toward the cyanide reading
        // --- Visual (windowed-only; ignored by the gameplay field) ---
        almond_tint: (0.92, 0.85, 0.70),  // pale almond/cream base (linear RGB)
        min_visible_level: 11.0,   // draw a puddle only above this volume (visual-only). Sets how far out from
                                   // each spring reads as wet; with pool_spacing=8 + diffuse=0.02 this yields
                                   // discrete 2–5 tile puddles (see the `almond_pools_stay_small` harness test).
        film_thickness_nm: 320.0,  // thin-film thickness — sets the iridescence hue via optical path difference
        film_ior: 1.33,            // index of refraction of the water film (must be >= 1)
        iridescence_strength: 0.25,// subtle oil-slick sheen; more water = more sheen
        moisture_feed_gain: 0.3,   // how strongly water level boosts the mold's Gray-Scott bloom where they overlap
        iridescence_mute: 0.6,     // pull thin-film reflectance toward its mean (1=rainbow, 0=grey); was hardcoded
        poison_tint: (0.55, 0.70, 0.40), // sickly hue of a pool the population reads as cyanide (belief 0)
    ),
    // The DETERMINISTIC CPU gameplay mold (src/mold.rs) — Fisher-KPP reaction-diffusion over the dungeon
    // grid, in the harness (optimizer-tunable), distinct from the GPU cosmetic `mycelia` above. Grows in the
    // same `mycelia.habitat` mask, spreads, and recedes from the squad's light. Couplings dim light / occlude
    // LOS / boost almond-water seep.
    mold: (
        growth: 0.08,          // logistic growth coeff per substep, toward habitat capacity
        diffuse: 0.12,         // diffusion lerp weight per substep (must be < 0.25 for a stable step)
        substeps: 4,           // reaction-diffusion substeps per FixedUpdate tick
        seed_v: 0.15,          // initial biomass seeded into each habitat cell at bake
        light_recoil: 0.05,    // recoil sink per substep per unit illuminance — the photophobia strength
        light_ref: 6.0,        // illuminance that reads as fully lit (light01 = min(1, light / light_ref))
        dim_light: 0.5,        // biomass -> LightField attenuation (mold darkens rooms; crabs less light-pushed)
        occlude_los: 0.6,      // dense mold (biomass >= ~0.83) hides crabs from squad LOS (tactical cost; tunable 0..1.5)
        seep_boost: 1.5,       // dense biomass -> almond-water seep multiplier (live; mirrors old mold_seep_mult)
        dense_v: 0.5,          // biomass at/above which a cell counts as "dense" mold (LOS + seep)
    ),
    // Acoustic-stimulus + audio tuning (src/audio_tuning.rs). Makes sound a perception stimulus:
    // gameplay sounds deposit into the acoustic stigmergy channels (ai::field::NOISE_*) and agents
    // react to them. `stimulus` = channel propagation (evaporate/diffuse/deposit_radius, same model as
    // ai_tuning.fields) + per-event loudness (deposit amount). `perception` = per-faction reaction gains.
    // The cosmetic waveform mix stays in code (src/audio.rs) and is NOT tuned here.
    audio: (
        stimulus: (
            noise_squad: (evaporate: 2.492324, diffuse: 0.20195086, deposit_radius: 8.0),
            noise_swarm: (evaporate: 0.09777509, diffuse: 0.15594381, deposit_radius: 7.540029),
            fire_loudness: 0.0,
            impact_wall_loudness: 0.2898777,
            impact_flesh_loudness: 0.15307344,
            enemy_death_loudness: 0.9537805,
            unit_death_loudness: 0.7733592,
        ),
        perception: (
            // Sound-as-perception ON (FIX 2): din-response gains ship positive so a firefight shapes the
            // battlefield. crab_draw_to_din > crab_fear_of_din ⇒ the swarm converges on gunfire. Must stay
            // byte-identical to AudioTuning::default() (audio_default_equals_shipped_config guards it).
            crab_fear_of_din: 0.35405704,
            unit_fear_of_din: 0.3944512,
            crab_draw_to_din: 0.20777673,
            investigate_threshold: 0.22598898,
        ),
    ),
)
